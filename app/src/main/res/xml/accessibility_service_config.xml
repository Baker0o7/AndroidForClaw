<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Accessibility Service Configuration
    This configuration defines how the automation tool interacts with Android's accessibility service framework
    to get complete View Tree information and perform related operations.
    
    accessibilityEventTypes: Types of accessibility events to listen for, typeAllMask means listening to all event types
    accessibilityFeedbackType: Accessibility feedback type, feedbackGeneric means generic feedback
    notificationTimeout: Event notification timeout in milliseconds
    canRequestTouchExplorationMode: Whether to request touch exploration mode
    canPerformGestures: Whether to perform gesture operations
    canRetrieveWindowContent: Whether to retrieve window content, crucial for getting View Tree information
    canRequestEnhancedWebAccessibility: Whether to request enhanced web accessibility support
    canRequestFilterKeyEvents: Whether to filter key events
    accessibilityFlags: Accessibility service flags for controlling service behavior
        - flagRetrieveInteractiveWindows: Retrieve interactive window content
        - flagIncludeNotImportantViews: Include not important views (currently unused)
        - flagRequestEnhancedWebAccessibility: Request enhanced web accessibility
        - flagReportViewIds: Report view IDs
        - flagRequestFilterKeyEvents: Request filter key events
    settingsActivity: Settings Activity class name
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeAllMask"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:notificationTimeout="100"
    android:canRequestTouchExplorationMode="true"
    android:canPerformGestures="true"
    android:canRetrieveWindowContent="true"
    android:canRequestEnhancedWebAccessibility="true"
    android:canRequestFilterKeyEvents="true"
    android:accessibilityFlags="flagRetrieveInteractiveWindows|flagRequestEnhancedWebAccessibility|flagReportViewIds|flagRequestFilterKeyEvents"
    android:settingsActivity="com.example.accessibilitytool.SettingsActivity" />
